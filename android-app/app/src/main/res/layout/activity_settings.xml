<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/settingsBackButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/button_icon_subtle"
                android:contentDescription="@string/settings_back"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/eehh_ink" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textColor="@color/eehh_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/settingsProgress"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_surface"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="@string/settings_account_title"
                android:textColor="@color/eehh_accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settingsAccountStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/eehh_ink"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/eehh_muted"
                android:textSize="12sp" />

            <Button
                android:id="@+id/settingsLogoutButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_ghost"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="@string/main_logout_button"
                android:textColor="@color/eehh_ink"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_surface"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="@string/settings_sync_title"
                android:textColor="@color/eehh_accent"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/settingsAutoSyncSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_auto_sync_label"
                android:textColor="@color/eehh_ink" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/settingsRefreshSnapshotSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_refresh_snapshot_label"
                android:textColor="@color/eehh_ink" />

            <TextView
                android:id="@+id/settingsOfflineSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/eehh_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/settingsSnapshotIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/eehh_easy"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/settingsSyncWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:text="@string/settings_session_warning_inline"
                android:textColor="@color/eehh_danger"
                android:textSize="13sp"
                app:drawableStartCompat="@android:drawable/ic_dialog_alert"
                android:visibility="gone" />

            <Button
                android:id="@+id/settingsSyncNowButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_primary"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="@string/settings_sync_now"
                android:textColor="#04231F"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsRefreshSnapshotButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_ghost"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="@string/settings_refresh_snapshot_now"
                android:textColor="@color/eehh_ink"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_surface"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="@string/reminder_title"
                android:textColor="@color/eehh_accent"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/settingsReminderSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/reminder_toggle_label"
                android:textColor="@color/eehh_ink" />

            <Button
                android:id="@+id/settingsReminderTimeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_ghost"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:textColor="@color/eehh_ink"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/panel_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_surface"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="@string/settings_data_title"
                android:textColor="@color/eehh_accent"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_clear_data_hint"
                android:textColor="@color/eehh_muted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsClearDataButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_ghost"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="@string/settings_clear_data_button"
                android:textColor="@color/eehh_danger"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>