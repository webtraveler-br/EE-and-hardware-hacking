<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#273244" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#3A4A62" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#233449" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#4F6E95" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1C2B3E" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#3D5A7D" />
        </shape>
    </item>
</selector>
