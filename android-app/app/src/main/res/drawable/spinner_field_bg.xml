<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1E3250" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/eehh_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#192A41" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/eehh_panel_border" />
        </shape>
    </item>
</selector>
