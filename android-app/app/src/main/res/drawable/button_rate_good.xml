<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#273244" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#3A4A62" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#204F54" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#35A392" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A4147" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#2D8F87" />
        </shape>
    </item>
</selector>
