<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#273244" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#3A4A62" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#284965" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#5C8CC5" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#23425C" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#4B7EAF" />
        </shape>
    </item>
</selector>
