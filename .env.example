APP_NAME=Roadmap EE&HH
# Obrigatoria em qualquer ambiente; troque por uma chave aleatoria longa.
APP_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
SESSION_COOKIE_NAME=roadmap_session
SESSION_HOURS=336
# Em producao HTTPS, ajuste para true
COOKIE_SECURE=false

DATABASE_URL=sqlite:////srv/roadmap/data/study_os.db
ROADMAP_WORKSPACE_ROOT=/srv/roadmap/workspace
FLASHCARD_ROOT=/srv/roadmap/workspace/content/flashcards

POW_DIFFICULTY=3
POW_TTL_SECONDS=180
AUTH_RATE_LIMIT_PER_MINUTE=20
CHALLENGE_RATE_LIMIT_PER_MINUTE=80
REVIEW_RATE_LIMIT_PER_MINUTE=240
FSRS_DESIRED_RETENTION=0.9

WEB_PORT=8088

# UID/GID do usuario do host para escrita no volume ./data
APP_UID=1000
APP_GID=1000
